{
  "name": "quality-autopilot-automation",
  "version": "1.0.0",
  "description": "BDD+POM Automation Framework using Playwright and Cucumber",
  "scripts": {
    "test": "cucumber-js -r step_definitions/**/*.ts -r hooks/**/*.ts --require-module ts-node/register",
    "test:headed": "cucumber-js -r step_definitions/**/*.ts -r hooks/**/*.ts --require-module ts-node/register --headed",
    "test:debug": "cucumber-js -r step_definitions/**/*.ts -r hooks/**/*.ts --require-module ts-node/register --debug",
    "report": "cucumber-js -r step_definitions/**/*.ts -r hooks/**/*.ts --require-module ts-node/register --format json:reports/cucumber-report.json",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "allure:generate": "allure generate reports/allure-results --clean -o reports/allure-report",
    "allure:open": "allure open reports/allure-report",
    "allure:clean": "allure clean reports/allure-results"
  },
  "dependencies": {
    "@cucumber/cucumber": "^12.8.0",
    "@playwright/test": "^1.42.0",
    "@types/node": "^20.11.0",
    "@allure-report/cucumber": "^3.0.0",
    "allure-commandline": "^2.27.0",
    "cross-env": "^7.0.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "eslint": "^8.56.0"
  }
}
