# ------------------------------------------
# Required: API Keys
# ------------------------------------------

# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ------------------------------------------
# Optional: API Keys (Fallback Models)
# ------------------------------------------

# Anthropic (Claude models)
# ANTHROPIC_API_KEY=

# Google (Gemini models)
# GOOGLE_API_KEY=

# GitHub integration for Engineer agent PRs
# GITHUB_TOKEN=

# ------------------------------------------
# Jira Integration
# ------------------------------------------

# Jira URL for your instance
JIRA_URL=https://lokeshsharma2.atlassian.net

# Jira username (email)
JIRA_USERNAME=kirtisharma0691@gmail.com

# Jira API token (generate from https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN=

# ------------------------------------------
# Ollama (Local/Cloud Fallback LLM)
# ------------------------------------------

# Default assumes Ollama running on host machine.
# Docker accesses host via host.docker.internal.
# OLLAMA_HOST=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.1:8b

# ------------------------------------------
# AUT (Application Under Test)
# ------------------------------------------

# The web application the agents will test.
AUT_BASE_URL=https://demo.nopcommerce.com/
# AUT_AUTH_USER=
# AUT_AUTH_PASS=

# ------------------------------------------
# Database
# ------------------------------------------

# Defaults work out of the box with Docker Compose.
# Only change these if you're using an external database.
# DB_USER=ai
# DB_PASS=ai
# DB_HOST=localhost
# DB_PORT=5432
# DB_DATABASE=ai

# ------------------------------------------
# Runtime
# ------------------------------------------

# "dev" enables hot-reload, "prd" enables JWT RBAC.
# RUNTIME_ENV=dev

# ------------------------------------------
# Production: Security
# ------------------------------------------

# RBAC is enabled automatically when RUNTIME_ENV=prd.
# Generate a key pair at os.agno.com -> Settings.
# JWT_VERIFICATION_KEY=

# ------------------------------------------
# Azure DevOps Integration
# ------------------------------------------

# Azure DevOps URL for your organization
AZURE_DEVOPS_URL=https://dev.azure.com/vibecode/

# Azure DevOps email
AZURE_DEVOPS_EMAIL=lokesh.sharma3@cognizant.com

# Azure DevOps Personal Access Token (PAT)
# Generate from: https://dev.azure.com/{organization}/_usersSettings/tokens
AZURE_DEVOPS_PAT=
