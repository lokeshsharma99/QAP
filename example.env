# ===========================================================================
# Quality Autopilot — Environment Configuration
# ===========================================================================
# Copy this file to .env and fill in your values.
#
#   cp example.env .env
#
# SECURITY: Never commit .env to git. Only example.env is tracked.
# ===========================================================================

# ---------------------------------------------------------------------------
# LLM / Inference Providers
# ---------------------------------------------------------------------------
# Quality Autopilot supports multiple OpenAI-compatible providers.
# Set one up and switch between them live in Settings → Provider & Model.

# ── Kilo AI (default — free tier available) ──────────────────────────────
# Sign up at: https://app.kilo.ai
# Free tier uses kilo-auto/free; any real key upgrades to kilo-auto/balanced.
KILO_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://api.kilo.ai/api/openrouter/v1

# ── GitHub Copilot (local proxy) ─────────────────────────────────────────
# Requires the "Copilot Chat" VS Code extension to be running — it exposes
# an OpenAI-compatible server on 127.0.0.1:3030.
# API key is not required (the extension handles auth).
GITHUB_COPILOT_BASE_URL=http://127.0.0.1:3030/v1
GITHUB_COPILOT_API_KEY=optional

# ── NVIDIA NIM ────────────────────────────────────────────────────────────
# Get a free API key at: https://build.nvidia.com
# Models: qwen3-coder-480b, llama-3.3-70b, nemotron-70b, phi-3-medium, gemma-2-27b
NVIDIA_API_KEY=

# ── Model provider switcher ───────────────────────────────────────────────
# Set MODEL_PROVIDER to change the LLM used by ALL agents without editing code.
# Observed TTFT on ~19k token contexts in this deployment:
#   nvidia     → ~1-3s TTFT, 200+ t/s    (NVIDIA NIM — DEFAULT, requires NVIDIA_API_KEY)
#   kilo       → avg 23s TTFT, spikes to 94s (shared NVIDIA NIM free queue)
#   kilo_paid  → ~3-8s TTFT (priority queue, requires KILO_API_KEY)
#   gemini     → ~1-3s TTFT, 200-500 t/s (requires GOOGLE_API_KEY)
#   gpt4o_mini → ~0.5-2s TTFT, 200+ t/s  (requires OPENAI_API_KEY)
#   haiku      → ~1-2s TTFT, 200+ t/s    (requires ANTHROPIC_API_KEY)
# Optional: override the NVIDIA model (default: qwen/qwen3-coder-480b-a35b-instruct)
# NVIDIA_MODEL=nvidia/llama-3.3-70b-instruct
MODEL_PROVIDER=nvidia

# Keys for alternative providers (only needed when MODEL_PROVIDER is set above)
GOOGLE_API_KEY=AIzaSyDT-NX1ztkmacWpaSH0QpVqxwN849Cpl3M
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# Microsoft Teams — Power Automate HITL notification
# ---------------------------------------------------------------------------
# HTTP trigger URL from the Power Automate flow that posts RCA reports
# to your MS Teams channel as Adaptive Cards.
#
# Flow: Detective calls post_rca_to_teams (requires_confirmation=True)
#   → Agno writes one approval record to DB
#   → Human Lead approves in /approvals OR in chat (both sync from same DB record)
#   → On approval: POST fires → Teams Adaptive Card posted in channel
#
# To get this URL:
#   Power Automate → Create a flow with "When an HTTP request is received" trigger
#   → add "Post adaptive card in a chat or channel" action → copy the URL
POWER_AUTOMATE_TEAMS_URL=

# ------------------------------------------
# Slack Bot
# ------------------------------------------
# Bot token (xoxb-...) — requires chat:write scope
SLACK_BOT_TOKEN=
# Channel ID (e.g. C0B12TFRR7V) or channel name (#channel)
SLACK_CHANNEL=

# ---------------------------------------------------------------------------
# Playwright MCP  (browser automation for Discovery + Medic agents)
# ---------------------------------------------------------------------------
# Option A — Dedicated Docker service (headed/headless chromium):
#   docker compose --profile mcp up -d
#   PLAYWRIGHT_MCP_URL is already set in compose.yaml (http://playwright-mcp:8931)
#   Set it here only if you need to override the URL (e.g. local dev outside Docker):
# PLAYWRIGHT_MCP_URL=http://localhost:8931
#
# Option B — No service needed (default):
#   Leave PLAYWRIGHT_MCP_URL unset.
#   Discovery + Medic will spawn: npx -y @playwright/mcp@latest --headless --no-sandbox
#   Node.js is pre-installed in the qap-api image, so this works automatically.

# ---------------------------------------------------------------------------
# Ollama  (local instance + cloud models)
# ---------------------------------------------------------------------------
# Install:    https://ollama.ai
# Pull model: ollama pull qwen3-embedding:4b
#
# Use http://localhost:11434 for local dev (outside Docker).
# Use http://host.docker.internal:11434 inside Docker containers.
OLLAMA_HOST=http://host.docker.internal:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434

# Ollama cloud models — sign in with `ollama signin` to use :cloud tags via local daemon,
# or set OLLAMA_API_KEY for direct access to https://ollama.com/api.
# Create an API key at: https://ollama.com/settings/keys
OLLAMA_API_KEY=d73713609e8f49d5a23bb9f10c9a71ad.JyU1-4aG84TzTh7Jakc9wc-a
# Default model and available cloud model list (comma-separated)
OLLAMA_MODEL=minimax-m2.7:cloud
OLLAMA_MODELS=minimax-m2.7:cloud,glm-5.1:cloud,qwen3-coder-next

# ---------------------------------------------------------------------------
# GitHub Integration  (for PR creation by Engineer agent + GitHub MCP tools)
# ---------------------------------------------------------------------------
# Get a PAT at: https://github.com/settings/tokens
# Required scopes: repo, read:org, read:project, workflow
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# AUT — Application Under Test (GDS Demo App)
# ---------------------------------------------------------------------------
AUT_BASE_URL=https://lokeshsharma99.github.io/GDS-Demo-App/
# AUT_AUTH_USER=
# AUT_AUTH_PASS=

# AUT GitHub repo — used by GitHub MCP tools (Architect, Discovery, Engineer, Detective)
AUT_GITHUB_OWNER=lokeshsharma99
AUT_GITHUB_REPO=GDS-Demo-App
AUT_PRODUCTION_URL=https://lokeshsharma99.github.io/GDS-Demo-App/
AUT_ALLURE_REPORT_URL=https://lokeshsharma99.github.io/GDS-Demo-App/allure-report/
AUT_GITHUB_PROJECT_URL=https://github.com/users/lokeshsharma99/projects/6/views/1
AUT_SONARCLOUD_URL=https://sonarcloud.io/summary/overall?id=lokeshsharma99_GDS-Demo-App&branch=main

# ---------------------------------------------------------------------------
# SonarQube  (static analysis + quality gate — docker compose --profile sonar up -d)
#
# Local SonarQube (runs as a Docker container on port 9000):
#   SONAR_URL=http://localhost:9000
#   SONAR_TOKEN=squ_xxxx              # generate at http://localhost:9000/account/security
#   SONAR_PROJECT_KEY=quality-autopilot-automation
#   SONAR_DB=sonarqube                # Postgres DB name for SonarQube data
#   SONAR_MCP_URL=http://localhost:9001/mcp  # SonarQube MCP server (wraps REST API)
#
# SonarCloud (cloud alternative — no local container needed):
#   SONAR_URL=https://sonarcloud.io
#   SONAR_TOKEN=<SonarCloud token>
#   SONAR_PROJECT_KEY=<org>_quality-autopilot-automation
#   SONAR_ORGANIZATION=<your SonarCloud org key>
# ---------------------------------------------------------------------------
# SONAR_URL=http://localhost:9000
# SONAR_TOKEN=
# SONAR_PROJECT_KEY=quality-autopilot-automation
# SONAR_DB=sonarqube
# SONAR_MCP_URL=http://localhost:9001/mcp

# ---------------------------------------------------------------------------
# Jira Integration  (for Architect agent — ticket parsing)
# ---------------------------------------------------------------------------
# JIRA_URL=https://your-domain.atlassian.net
# JIRA_USERNAME=your-email@example.com
# JIRA_API_TOKEN=

# ---------------------------------------------------------------------------
# Azure DevOps  (CI Log Analyzer + Pipeline Analyst + Architect)
# ---------------------------------------------------------------------------
# AZURE_DEVOPS_URL=https://dev.azure.com/your-org
# AZURE_DEVOPS_EMAIL=user@example.com
# AZURE_DEVOPS_PAT=          # Personal Access Token — also used by ADO MCP server
# AZURE_DEVOPS_PROJECT=      # Default project name (e.g. MyProject)
#
# Azure DevOps MCP Server (@azure-devops/mcp)
# The org name is auto-extracted from AZURE_DEVOPS_URL.
# AZURE_DEVOPS_PAT is reused as AZURE_DEVOPS_EXT_PAT for headless MCP auth.
# Domains loaded per agent:
#   pipeline_analyst  — core, pipelines, repositories
#   ci_log_analyzer   — core, pipelines, work-items
#   architect         — core, work-items
# No extra variables needed beyond AZURE_DEVOPS_URL + AZURE_DEVOPS_PAT.

# ---------------------------------------------------------------------------
# Atlassian MCP  (sooperset/mcp-atlassian — Architect, Scribe, CI Log Analyzer)
# ---------------------------------------------------------------------------
# Community MCP server with 72 Jira + Confluence tools.
# Works out-of-the-box with a standard API token — no org-admin required.
# Docker image: ghcr.io/sooperset/mcp-atlassian
#
# 1. Create an API token: https://id.atlassian.com/manage-profile/security/api-tokens
# 2. Start the service: docker compose up -d atlassian-mcp
#
ATLASSIAN_URL=https://lokeshsharma2.atlassian.net
ATLASSIAN_EMAIL=kirtisharma0691@gmail.com
ATLASSIAN_API_TOKEN=
# Confluence URL — defaults to ATLASSIAN_URL + /wiki if left blank
ATLASSIAN_CONFLUENCE_URL=https://lokeshsharma2.atlassian.net/wiki


# ---------------------------------------------------------------------------
# Optional: Enhanced Search
# ---------------------------------------------------------------------------
# EXA_API_KEY=
# PARALLEL_API_KEY=

# ---------------------------------------------------------------------------
# Email — Invite emails sent by Organization API (POST /organization/members)
# ---------------------------------------------------------------------------
# Set these to enable real invite emails.  Leave blank to skip email sending.
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey               # SendGrid: literal string "apikey"
# SMTP_PASS=                     # SendGrid API key or SMTP password
# INVITE_FROM_EMAIL=noreply@yourdomain.com
# APP_BASE_URL=https://app.yourdomain.com  # Used to build signup link in invite email

# ---------------------------------------------------------------------------
# Semantica — Decision Intelligence + Context Graphs + Provenance
# ---------------------------------------------------------------------------
# pip install semantica[agno]>=0.4.0  (already in requirements.txt)
# Docs: https://github.com/Hawksight-AI/semantica
#
# Master switch — set to true to activate all Semantica features
SEMANTICA_ENABLED=false
#
# Per-agent switches (only active when SEMANTICA_ENABLED=true)
SEMANTICA_JUDGE_ENABLED=true       # Decision tracking + precedent search in Judge
SEMANTICA_DETECTIVE_ENABLED=true   # Rete-based RCA classification in Detective
SEMANTICA_MEDIC_ENABLED=true       # Healing decision tracking in Medic
SEMANTICA_CI_LOG_ANALYZER_ENABLED=false
SEMANTICA_LIBRARIAN_ENABLED=true   # KG conflict detection + entity resolution in Librarian
SEMANTICA_ARCHITECT_ENABLED=true   # Context graphs + requirement traceability in Architect
#
# Per-feature switches
SEMANTICA_DECISION_TRACKING_ENABLED=true   # Record every approval/RCA/heal decision
SEMANTICA_PROVENANCE_ENABLED=true          # W3C PROV-O lineage across all agents
SEMANTICA_TEMPORAL_ENABLED=false           # Temporal intelligence (v0.4+ feature)

# ---------------------------------------------------------------------------
# Database  (defaults work with Docker Compose out of the box)
# ---------------------------------------------------------------------------
# DB_USER=ai
# DB_PASS=ai
# DB_HOST=localhost
# DB_PORT=5432
# DB_DATABASE=ai

# ---------------------------------------------------------------------------
# Runtime
# ---------------------------------------------------------------------------
# RUNTIME_ENV=dev       # dev | prd
# PRINT_ENV_ON_LOAD=False
